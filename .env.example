# ============================================================
# NDQS Platform — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ----- Database -----
# PostgreSQL connection string (asyncpg driver for async SQLAlchemy)
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=

# ----- OAuth: GitHub -----
# Create at: https://github.com/settings/developers

# GitHub OAuth App — Client ID
GITHUB_CLIENT_ID=

# GitHub OAuth App — Client Secret
GITHUB_CLIENT_SECRET=

# ----- OAuth: Google -----
# Create at: https://console.cloud.google.com/apis/credentials

# Google OAuth — Client ID
GOOGLE_CLIENT_ID=

# Google OAuth — Client Secret
GOOGLE_CLIENT_SECRET=

# ----- JWT Authentication -----
# Secret key for signing JWT access tokens (min 32 chars, random)
JWT_SECRET_KEY=

# Secret key for signing JWT refresh tokens (min 32 chars, random, different from above)
JWT_REFRESH_SECRET=

# ----- LLM Gateway -----
# OpenRouter API key for LLM Judge / Game Master
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ----- Redis -----
# Redis connection URL for caching, rate limiting, and token blacklist
# Format: redis://host:port/db
REDIS_URL=
