# =============================================================================
# NDQS Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- Database ---

# PostgreSQL connection string (asyncpg driver for SQLAlchemy async)
DATABASE_URL=postgresql+asyncpg://ndqs:ndqs@localhost:5432/ndqs

# --- Auth: GitHub OAuth ---

# GitHub OAuth App client ID (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id

# GitHub OAuth App client secret
GITHUB_CLIENT_SECRET=your-github-client-secret

# --- Auth: Google OAuth ---

# Google OAuth client ID (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id

# Google OAuth client secret
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Auth: JWT ---

# Secret key for signing JWT access tokens. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-jwt-secret-key

# Secret key for signing JWT refresh tokens. Generate with: openssl rand -hex 32
JWT_REFRESH_SECRET=your-jwt-refresh-secret

# --- LLM: OpenRouter ---

# OpenRouter API key for LLM Judge / Game Master (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your-openrouter-api-key

# --- Cache: Redis ---

# Redis connection URL for caching, rate limiting, and token blacklist
REDIS_URL=redis://localhost:6379/0

# --- Application ---

# Environment: development | production
ENVIRONMENT=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Frontend URL for CORS allowlist
FRONTEND_URL=http://localhost:3000

# Backend base URL
BACKEND_URL=http://localhost:8000
