<div class="flex items-center gap-1.5">
  <!-- Ukończony -->
  <div class="h-2 flex-1 rounded-sm bg-ndqs-gold shadow-[0_0_8px_rgba(229,181,92,0.5)]" />
  <div class="h-2 flex-1 rounded-sm bg-ndqs-gold shadow-[0_0_8px_rgba(229,181,92,0.5)]" />
  <!-- W trakcie (pulsuje) -->
  <div class="h-2 flex-1 rounded-sm bg-ndqs-gold/60 animate-pulse" />
  <!-- Zablokowane -->
  <div class="h-2 flex-1 rounded-sm bg-white/[0.08]" />
  <div class="h-2 flex-1 rounded-sm bg-white/[0.08]" />
  <div class="h-2 flex-1 rounded-sm bg-white/[0.08]" />
</div>
```

